# ── LLM ──────────────────────────────────────────────────────────────────────
MODEL=openrouter/meta-llama/llama-3.3-70b-instruct   # dev default; switch to claude-sonnet for prod
OPENROUTER_API_KEY=your_key_here

# Alternative: use Gemini directly (free tier)
# MODEL=gemini/gemini-1.5-flash
# GEMINI_API_KEY=your_key_here

# ── Search ───────────────────────────────────────────────────────────────────
SERPER_API_KEY=your_key_here          # SerperDev — used by audience crew agents

# ── Meta Ads (Phase 3 — Task 3.1) ────────────────────────────────────────────
# META_ACCESS_TOKEN=your_token_here   # Long-lived token (60-day expiry — set a calendar reminder)
# META_AD_ACCOUNT_ID=act_XXXXXXXXXX   # Format: act_ prefix + numeric ID — from Business Suite → Settings → Ad Accounts
# META_PAGE_ID=your_page_id           # From Business Suite → Settings → Pages
# META_PIXEL_ID=your_pixel_id         # From Meta Events Manager → Data Sources (optional, for conversion tracking)
# DRY_RUN=true                        # Set to false ONLY when ready for live deployment
# META_APP_ID=your_app_id
# META_APP_SECRET=your_app_secret
# DRY_RUN=true                        # Set to false ONLY when ready for live deployment

# ── Email — Brevo (Phase 3 — Task 3.3) ───────────────────────────────────────
# BREVO_API_KEY=your_key_here

# ── WhatsApp (Phase 3 — Task 3.4) ────────────────────────────────────────────
# INTERAKT_API_KEY=your_key_here      # OR WhatsApp Business Cloud API token

# ── Notifications (optional) ─────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=your_webhook_url  # For human review notifications (Task 1.4)
