# Local-only scratch at the repo root: manual LLM runs, ad-hoc pipeline tests, and
# generated prompt dumps. Throwaway dev artifacts — not part of the package.
# Leading slash anchors these to the root so the real tests/ suite is untouched.
/_manual_llm_outputs*.py
/test_*.py
/*_prompts*.txt
/tasklist.md
/scratch_graph.py

# Generated image + prompt output directories (all test renders, baked outputs)
baked_out/
test_images/
test_output/

# Archived old pipeline — not part of active codebase
old_image_generation/

# Root-level generated JSON data blobs (visual prompts, ad data dumps)
/*_visual_prompts*.json
/anamika_heights_*.json

# Log files at repo root
/*.log

# Pytest / test cache
.pytest_cache/
